---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Fractune — Measure what buildings make you feel">
  <!-- Navigation -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo"><img src="/logo.png" alt="" class="nav-logo-icon" />Fractune</a>
      <div class="nav-links">
        <a href="https://sites.fractune.dk">Map</a>
        <a href="/privacy">Privacy</a>
        <a href="/support">Support</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <h1 class="hero-title">
        Some buildings<br />
        <span class="hero-accent">feel right.</span>
      </h1>
      <p class="hero-subtitle">Now you can measure why.</p>
      <div class="hero-cta">
        <a
          href="https://apps.apple.com/app/fractune/idXXXXXXXXXX"
          class="btn btn-primary"
        >
          Download on the App Store
        </a>
      </div>
    </div>
  </section>

  <!-- What it does -->
  <section class="explain">
    <div class="explain-image-wrap">
      <img src="/varde-lethgori.jpg" alt="Varde Teater & Musikhus — layered red timber facades with varying rhythms" class="explain-image" />
    </div>
    <div class="explain-inner">
      <h2 class="explain-title">Every facade has a fractal fingerprint.<br />Fractune reads it.</h2>
      <p class="explain-body">
        Point your camera at any building. Fractune calculates its fractal
        dimension &mdash; a single number that captures the complexity your
        eye already senses. Research shows we prefer buildings around
        D&nbsp;=&nbsp;1.3&ndash;1.5, the same range found in trees, coastlines,
        and the architecture we have loved for centuries.
      </p>
      <p class="explain-credit">Varde Teater &amp; Musikhus &middot; <a href="https://lethgori.dk" rel="noopener" target="_blank">Leth &amp; Gori</a></p>
    </div>
  </section>

  <!-- Map -->
  <section class="map-section">
    <div class="map-section-inner">
      <h2 class="map-section-title">A growing map of architectural complexity.</h2>
      <p class="map-section-body">
        Every scan adds to a shared, open dataset. Explore how buildings
        compare across neighbourhoods, cities, and styles.
      </p>
      <a href="https://sites.fractune.dk" class="btn btn-secondary">Explore the map</a>
    </div>
  </section>

  <!-- How it works -->
  <section class="how">
    <div class="how-inner">
      <div class="how-step">
        <span class="how-number">1</span>
        <h3>Point</h3>
        <p>Frame the facade in your camera.</p>
      </div>
      <div class="how-step">
        <span class="how-number">2</span>
        <h3>Scan</h3>
        <p>Fractune analyses on-device. Your photos never leave your phone.</p>
      </div>
      <div class="how-step">
        <span class="how-number">3</span>
        <h3>Understand</h3>
        <p>Get the D-value &mdash; and see where it sits on the fluence scale.</p>
      </div>
    </div>
  </section>

  <!-- Science -->
  <section class="science">
    <div class="science-inner">
      <h2 class="science-title">Built on decades of research.</h2>
      <p class="science-body">
        Fractal fluence draws on the work of physicist Richard Taylor, who
        discovered that humans respond measurably to fractal patterns in
        art and architecture. Fractune builds on methods established by
        Ostwald &amp; Vaughan across 85 canonical buildings, and connects
        to the broader theory of predictive processing in environmental
        psychology.
      </p>
      <a href="/science" class="btn btn-secondary" style="margin-top: 2rem;">The science</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-links">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/license">Dataset Licence</a>
        <a href="/support">Support</a>
        <a href="https://sites.fractune.dk">Map</a>
      </div>
      <p class="footer-copy">&copy; {new Date().getFullYear()} Fractune &middot; Colours by Barslund</p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* Nav */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .nav-logo-icon {
    height: 1.0em;
    width: auto;
    vertical-align: middle;
    transform: translateY(-1px);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.875rem;
  }

  .nav-links a {
    color: var(--color-text-secondary);
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  /* Hero */
  .hero {
    padding: 12rem 2rem 6rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: clamp(2.8rem, 7vw, 4.5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin-bottom: 1rem;
  }

  .hero-accent {
    background: linear-gradient(135deg, #12283E, #2a5a8a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-text-secondary);
    line-height: 1.4;
    margin-bottom: 2.5rem;
  }

  .hero-cta {
    display: flex;
    justify-content: center;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    border-radius: 980px;
    font-size: 1rem;
    font-weight: 500;
    transition: all var(--transition);
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-bg-secondary);
    color: var(--color-accent-hover);
  }

  /* Explain */
  .explain {
    padding: 0 0 6rem;
    text-align: center;
    background: var(--color-bg-secondary);
  }

  .explain-image-wrap {
    width: 100%;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    margin-bottom: 3rem;
  }

  .explain-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  .explain-inner {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .explain-credit {
    margin-top: 1.5rem;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    opacity: 0.7;
  }

  .explain-credit a {
    color: var(--color-text-secondary);
    text-decoration: underline;
  }

  .explain-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .explain-body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  /* Map section */
  .map-section {
    padding: 6rem 2rem;
    text-align: center;
  }

  .map-section-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .map-section-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .map-section-body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  /* How it works */
  .how {
    padding: 6rem 2rem;
    background: var(--color-bg-secondary);
  }

  .how-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    text-align: center;
  }

  .how-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .how-step h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .how-step p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* Science */
  .science {
    padding: 6rem 2rem;
    text-align: center;
  }

  .science-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .science-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .science-body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  /* Footer */
  .footer {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }

  .footer-links a {
    color: var(--color-text-secondary);
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 600px) {
    .hero {
      padding: 9rem 1.25rem 4rem;
    }

    .hero-subtitle {
      font-size: 1.25rem;
    }

    .how-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .nav-links {
      gap: 1rem;
    }
  }
</style>
