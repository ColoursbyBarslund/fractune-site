---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Fractune — Measure what buildings make you feel">
  <!-- Navigation -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo"><img src="/logo.png" alt="" class="nav-logo-icon" />Fractune</a>
      <div class="nav-links">
        <a href="https://sites.fractune.dk">Map</a>
        <a href="/privacy">Privacy</a>
        <a href="/support">Support</a>
      </div>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <h1 class="hero-title">
          Some buildings feel right.<br />
          <span class="hero-accent">Now you can measure why.</span>
        </h1>
        <p class="hero-subtitle">
          Fractune reads the fractal fingerprint of any facade &mdash; a single number
          that captures the complexity your eye already senses.
        </p>
        <div class="hero-cta">
          <a
            href="https://apps.apple.com/app/fractune/idXXXXXXXXXX"
            class="btn btn-primary"
          >
            Download on the App Store
          </a>
        </div>
      </div>
    </section>

    <!-- What is fractal dimension? -->
    <section class="dimension">
      <div class="dimension-inner">
        <h2 class="section-title">What is fractal dimension?</h2>
        <p class="section-body">
          Fractal dimension measures how detail repeats across scales. Research by
          Taylor, Mandelbrot, and Salingaros shows humans consistently prefer
          buildings with D&nbsp;&asymp;&nbsp;1.3&ndash;1.5 &mdash; the same range found in nature.
        </p>

        <!-- D-value scale -->
        <div class="scale" role="figure" aria-label="Fractal dimension scale from 1.0 to 2.0">
          <div class="scale-bar">
            <div class="scale-sweet-spot" style="left: 30%; width: 20%;"></div>
            <div class="scale-marker" style="left: 10%;">
              <span class="scale-dot"></span>
              <span class="scale-label">D &asymp; 1.1</span>
              <span class="scale-desc">Blank glass facade</span>
            </div>
            <div class="scale-marker scale-marker-sweet" style="left: 35%;">
              <span class="scale-dot scale-dot-sweet"></span>
              <span class="scale-label">D &asymp; 1.3&ndash;1.5</span>
              <span class="scale-desc">Sweet spot</span>
            </div>
            <div class="scale-marker" style="left: 41%;">
              <span class="scale-dot scale-dot-small"></span>
              <span class="scale-label">D &asymp; 1.41</span>
              <span class="scale-desc">Avg. of 85 iconic buildings</span>
            </div>
            <div class="scale-marker" style="left: 70%;">
              <span class="scale-dot"></span>
              <span class="scale-label">D &asymp; 1.7</span>
              <span class="scale-desc">Gothic cathedral</span>
            </div>
          </div>
          <div class="scale-ends">
            <span>1.0 &mdash; Simple</span>
            <span>2.0 &mdash; Complex</span>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="how">
      <div class="how-inner">
        <h2 class="section-title">How it works</h2>
        <div class="how-steps">
          <div class="how-step">
            <span class="how-number">1</span>
            <h3>Point</h3>
            <p>Frame any building facade in your camera.</p>
          </div>
          <div class="how-step">
            <span class="how-number">2</span>
            <h3>Scan</h3>
            <p>Fractune analyses on-device using Canny edge detection and box-counting. Your photos never leave your phone.</p>
          </div>
          <div class="how-step">
            <span class="how-number">3</span>
            <h3>Understand</h3>
            <p>Get the D-value and see where it sits on the fluence scale.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature cards -->
    <section class="features">
      <div class="features-inner">
        <div class="feature-card">
          <h3>Fractal Analysis (D)</h3>
          <p>9-threshold robust plateau analysis with stability score.</p>
        </div>
        <div class="feature-card">
          <h3>Chromatic Fluence (C)</h3>
          <p>Entropy, palette coherence, and ecological deviation.</p>
        </div>
        <div class="feature-card">
          <h3>AI Segmentation</h3>
          <p>Analyse individual building elements using DETR.</p>
        </div>
        <div class="feature-card">
          <h3>Interactive Viewer</h3>
          <p>Switch between Original, Edges, Boxes, and Colours.</p>
        </div>
        <div class="feature-card">
          <h3>Session History</h3>
          <p>Side-by-side comparison and shareable report images.</p>
        </div>
        <div class="feature-card">
          <h3>Research Contribution</h3>
          <p>Anonymous opt-in data sharing via CloudKit.</p>
        </div>
        <div class="feature-card">
          <h3>Home Screen Widget</h3>
          <p>Quick access to your latest analysis.</p>
        </div>
      </div>
    </section>

    <!-- Science -->
    <section class="science">
      <div class="science-inner">
        <h2 class="section-title">Built on decades of research.</h2>
        <p class="section-body">
          Fractal fluence draws on the work of physicist Richard Taylor, who
          discovered that humans respond measurably to fractal patterns in
          art and architecture. Fractune builds on methods established by
          Ostwald &amp; Vaughan across 85 canonical buildings, and connects
          to the broader theory of predictive processing in environmental
          psychology.
        </p>
        <a href="/science" class="btn btn-secondary">The science</a>
      </div>
    </section>

    <!-- Map -->
    <section class="map-section">
      <div class="map-section-inner">
        <h2 class="section-title">A growing map of architectural complexity.</h2>
        <p class="section-body">
          Every scan adds to a shared, open dataset. Explore how buildings
          compare across neighbourhoods, cities, and styles.
        </p>
        <a href="https://sites.fractune.dk" class="btn btn-secondary">Explore the map</a>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-links">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/license">Dataset Licence</a>
        <a href="/support">Support</a>
        <a href="https://sites.fractune.dk">Map</a>
      </div>
      <p class="footer-copy">&copy; {new Date().getFullYear()} Fractune &middot; Colours by Barslund</p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ─── Nav ─── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .nav-logo-icon {
    height: 1.0em;
    width: auto;
    vertical-align: middle;
    transform: translateY(-1px);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.875rem;
  }

  .nav-links a {
    color: var(--color-text-secondary);
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  /* ─── Shared section styles ─── */
  .section-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
  }

  .section-body {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-width: 640px;
  }

  /* ─── Hero ─── */
  .hero {
    padding: 12rem 2rem 6rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: clamp(2.8rem, 7vw, 4.5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin-bottom: 1.25rem;
  }

  .hero-accent {
    color: var(--color-accent);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin-bottom: 2.5rem;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta {
    display: flex;
    justify-content: center;
  }

  /* ─── Buttons ─── */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    border-radius: 980px;
    font-size: 1rem;
    font-weight: 500;
    transition: all var(--transition);
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-bg-secondary);
    color: var(--color-accent-hover);
  }

  /* ─── Fractal dimension section ─── */
  .dimension {
    padding: 6rem 2rem;
    background: var(--color-bg-secondary);
    text-align: center;
  }

  .dimension-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .dimension .section-body {
    margin: 0 auto 3rem;
  }

  /* ─── D-value scale ─── */
  .scale {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .scale-bar {
    position: relative;
    height: 6px;
    background: var(--color-border);
    border-radius: 3px;
    margin-bottom: 5rem;
  }

  .scale-sweet-spot {
    position: absolute;
    top: 0;
    height: 100%;
    background: #2A7D3F;
    border-radius: 3px;
    opacity: 0.22;
  }

  .scale-marker {
    position: absolute;
    top: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .scale-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-text);
    border: 2px solid var(--color-bg-secondary);
    transform: translateY(-50%);
  }

  .scale-dot-sweet {
    background: #2A7D3F;
  }

  .scale-dot-small {
    width: 8px;
    height: 8px;
  }

  .scale-label {
    font-size: 0.8125rem;
    font-weight: 600;
    white-space: nowrap;
    margin-top: 0.25rem;
  }

  .scale-desc {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .scale-marker-sweet .scale-label {
    color: #2A7D3F;
  }

  .scale-ends {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-top: -3.5rem;
  }

  /* ─── How it works ─── */
  .how {
    padding: 6rem 2rem;
    text-align: center;
  }

  .how-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .how-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-top: 3rem;
  }

  .how-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .how-step h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .how-step p {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  /* ─── Feature cards ─── */
  .features {
    padding: 6rem 2rem;
    background: var(--color-bg-secondary);
  }

  .features-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    background: var(--color-bg);
    border-radius: var(--radius);
    padding: 2rem;
    border: 1px solid var(--color-border);
    transition: box-shadow var(--transition);
  }

  .feature-card:hover {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* ─── Science ─── */
  .science {
    padding: 6rem 2rem;
    text-align: center;
  }

  .science-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .science .section-body {
    margin: 0 auto 2rem;
  }

  /* ─── Map section ─── */
  .map-section {
    padding: 6rem 2rem;
    background: var(--color-bg-secondary);
    text-align: center;
  }

  .map-section-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .map-section .section-body {
    margin: 0 auto 2rem;
  }

  /* ─── Footer ─── */
  .footer {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }

  .footer-links a {
    color: var(--color-text-secondary);
  }

  .footer-links a:hover {
    color: var(--color-text);
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .features-inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 9rem 1.25rem 4rem;
    }

    .hero-title {
      font-size: clamp(2.2rem, 8vw, 3rem);
    }

    .hero-subtitle {
      font-size: 1.0625rem;
    }

    .how-steps {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .features-inner {
      grid-template-columns: 1fr;
    }

    .nav-links {
      gap: 1rem;
    }

    .scale-marker .scale-desc {
      display: none;
    }

    .scale-bar {
      margin-bottom: 3.5rem;
    }

    .scale-ends {
      margin-top: -2rem;
    }
  }
</style>
