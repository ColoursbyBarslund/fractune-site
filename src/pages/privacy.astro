---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy — Fractune">
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Fractune</a>
    </div>
  </nav>

  <main class="page">
    <div class="page-inner">
      <h1>Privacy Policy</h1>
      <p class="last-updated">Last updated: 17 April 2026</p>

      <h2>Data Collection</h2>
      <p>
        Fractune does not collect any personally identifiable information. The
        app generates an anonymous contributor ID locally on your device, used
        solely to associate your contributions with the public dataset.
      </p>

      <h2>Analysis and Image Processing</h2>
      <p>
        All image processing takes place locally on your device. Images are
        never uploaded to our servers. Only analysis results (D-value),
        coordinates, and metadata are sent to the public dataset.
      </p>

      <h2>Public Dataset</h2>
      <p>
        When you analyse a building, you contribute to a publicly accessible
        dataset via Apple CloudKit. The dataset contains: building name,
        location (coordinates), D-value, and time of analysis. No personal
        data is included.
      </p>

      <h2>Data Erasure</h2>
      <p>
        You may request deletion of all your contributions at any time. Send
        an email to <a href="mailto:privacy@fractune.dk">privacy@fractune.dk</a>
        with your contributor ID (found in the app under Settings). We will
        delete all associated data within 30 days.
      </p>

      <h2>Third-Party Services</h2>
      <p>
        Fractune uses Apple CloudKit for data storage and Apple MapKit JS
        for map display. These services are subject to Apple's
        <a href="https://www.apple.com/legal/privacy/" rel="noopener">privacy policy</a>.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about privacy? Contact us at
        <a href="mailto:privacy@fractune.dk">privacy@fractune.dk</a>.
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .nav { border-bottom: 1px solid var(--color-border); }
  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    height: 52px;
    display: flex;
    align-items: center;
  }
  .nav-logo { font-size: 1.25rem; font-weight: 600; color: var(--color-text); }
  .page { padding: 4rem 0; }
  .page-inner { max-width: 680px; margin: 0 auto; padding: 0 2rem; }
  h1 { font-size: 2rem; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 0.5rem; }
  .last-updated { color: var(--color-text-secondary); font-size: 0.875rem; margin-bottom: 2.5rem; }
  h2 { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; }
  p { font-size: 1rem; line-height: 1.7; color: var(--color-text-secondary); margin-bottom: 1rem; }
</style>
