---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Fractune Sites — Map"
  description="Explore buildings analysed with Fractune. View fractal fluence values (D-values) on an interactive map."
>
  <div class="map-page">
    <header class="map-header">
      <a href="/" class="map-logo">Fractune</a>
      <h1 class="map-title">Sites</h1>
    </header>
    <div id="map-container"></div>
    <div id="map-legend" class="map-legend">
      <h3>D-value scale</h3>
      <div class="legend-scale">
        <span class="legend-low">1.0</span>
        <div class="legend-gradient"></div>
        <span class="legend-high">2.0</span>
      </div>
      <p class="legend-desc">Lower = simpler geometry &middot; Higher = more complex</p>
    </div>
    <div id="site-detail" class="site-detail hidden">
      <button id="close-detail" class="close-btn" aria-label="Close">&times;</button>
      <h3 id="detail-title"></h3>
      <p class="detail-d-value">D-value: <strong id="detail-d"></strong></p>
      <p id="detail-address" class="detail-address"></p>
      <p id="detail-date" class="detail-date"></p>
    </div>
  </div>

  <script is:inline src="https://cdn.apple-mapkit.com/mk/5.x.x/mapkit.js" crossorigin async></script>

  <script is:inline>
    function initMap() {
      if (typeof mapkit === 'undefined') {
        setTimeout(initMap, 100);
        return;
      }

      mapkit.init({
        authorizationCallback: function (done) {
          fetch('/api/mapkit-token')
            .then(function (r) { return r.text(); })
            .then(done);
        },
      });

      // Wait for MapKit to be fully initialized before creating map
      mapkit.addEventListener('configuration-change', function (event) {
        if (event.status === 'Initialized') {
          var map = new mapkit.Map('map-container', {
            center: new mapkit.Coordinate(55.6761, 12.5683),
            region: new mapkit.CoordinateRegion(
              new mapkit.Coordinate(55.6761, 12.5683),
              new mapkit.CoordinateSpan(0.5, 0.5)
            ),
            showsCompass: mapkit.FeatureVisibility.Adaptive,
            showsScale: mapkit.FeatureVisibility.Adaptive,
            colorScheme: mapkit.Map.ColorSchemes.Light,
          });

          loadSites(map);
        }
      });
    }

    async function loadSites(map) {
      try {
        var res = await fetch('/api/sites');
        if (!res.ok) throw new Error('Failed to fetch sites');
        var data = await res.json();

        if (!data.sites || data.sites.length === 0) return;

        var annotations = data.sites.map(function (site) {
          var coord = new mapkit.Coordinate(site.latitude, site.longitude);
          var color = dValueToColor(site.dValue);

          var annotation = new mapkit.MarkerAnnotation(coord, {
            color: color,
            title: site.name || 'Building',
            subtitle: 'D = ' + site.dValue.toFixed(3),
            glyphText: site.dValue.toFixed(1),
          });

          annotation.addEventListener('select', function () {
            showDetail(site);
          });

          return annotation;
        });

        map.addAnnotations(annotations);

        if (annotations.length > 1) {
          map.showItems(annotations, {
            animate: true,
            padding: new mapkit.Padding(60, 60, 60, 60),
          });
        }
      } catch (err) {
        console.error('Error loading sites:', err);
      }
    }

    function dValueToColor(d) {
      var t = Math.max(0, Math.min(1, (d - 1.0) / 1.0));
      var r = Math.round(18 + t * 200);
      var g = Math.round(40 + t * 60);
      var b = Math.round(62 + t * 80);
      return 'rgb(' + r + ', ' + g + ', ' + b + ')';
    }

    function showDetail(site) {
      var panel = document.getElementById('site-detail');
      document.getElementById('detail-title').textContent = site.name || 'Building';
      document.getElementById('detail-d').textContent = site.dValue.toFixed(4);
      document.getElementById('detail-address').textContent = site.address || '';
      document.getElementById('detail-date').textContent = site.analyzedAt
        ? 'Analysed: ' + new Date(site.analyzedAt).toLocaleDateString('en-GB')
        : '';
      panel.classList.remove('hidden');
    }

    document.addEventListener('DOMContentLoaded', function () {
      var closeBtn = document.getElementById('close-detail');
      if (closeBtn) {
        closeBtn.addEventListener('click', function () {
          document.getElementById('site-detail').classList.add('hidden');
        });
      }
    });

    initMap();
  </script>
</BaseLayout>

<style>
  .map-page {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .map-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-border);
  }

  .map-logo {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .map-title {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-secondary);
  }

  #map-container {
    width: 100%;
    height: 100%;
  }

  .map-legend {
    position: absolute;
    bottom: 2rem;
    left: 1.5rem;
    z-index: 10;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    font-size: 0.8125rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .map-legend h3 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .legend-scale {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .legend-gradient {
    flex: 1;
    height: 8px;
    border-radius: 4px;
    background: linear-gradient(to right, #12283E, #2a5a8a, #4a8aba);
    min-width: 100px;
  }

  .legend-low,
  .legend-high {
    font-weight: 600;
    font-size: 0.75rem;
    color: var(--color-text);
  }

  .legend-desc {
    margin-top: 0.375rem;
    color: var(--color-text-secondary);
    font-size: 0.6875rem;
  }

  .site-detail {
    position: absolute;
    bottom: 2rem;
    right: 1.5rem;
    z-index: 10;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    min-width: 240px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: opacity 0.2s, transform 0.2s;
  }

  .site-detail.hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
  }

  .close-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    background: none;
    border: none;
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    cursor: pointer;
  }

  .site-detail h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .detail-d-value {
    font-size: 0.9375rem;
    margin-bottom: 0.25rem;
  }

  .detail-address,
  .detail-date {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }
</style>
