---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Fractune Sites — Map"
  description="Explore buildings analysed with Fractune. View fractal fluence values (D-values) on an interactive map."
>
  <div class="map-page">
    <header class="map-header">
      <a href="https://fractune.dk" class="map-logo"><img src="/logo.png" alt="" class="map-logo-icon" />Fractune</a>
      <h1 class="map-title">Sites</h1>
      <div id="filter-chips" class="filter-chips"></div>
      <div class="search-wrap">
        <input
          id="search-input"
          type="search"
          placeholder="Search..."
          class="search-input"
          autocomplete="off"
        />
        <span id="search-count" class="search-count"></span>
      </div>
    </header>

    <div id="map-container"></div>

    <div id="map-legend" class="map-legend">
      <h3>D-value range</h3>
      <div class="range-wrap">
        <span class="range-label">1.0</span>
        <div class="range-track" id="range-track">
          <div class="range-gradient"></div>
          <div class="range-selected" id="range-selected"></div>
          <div class="range-handle range-handle-left" id="handle-left" tabindex="0" role="slider" aria-label="Minimum D-value" aria-valuemin="1.0" aria-valuemax="2.0"></div>
          <div class="range-handle range-handle-right" id="handle-right" tabindex="0" role="slider" aria-label="Maximum D-value" aria-valuemin="1.0" aria-valuemax="2.0"></div>
        </div>
        <span class="range-label">2.0</span>
      </div>
      <p class="range-values" id="range-values">D 1.0 – 2.0</p>
      <p class="range-hint">Drag brackets to filter</p>
    </div>

    <!-- Detail panels container (stacks right-to-left) -->
    <div id="detail-panels" class="detail-panels"></div>
  </div>

  <script is:inline src="https://cdn.apple-mapkit.com/mk/5.x.x/mapkit.js" crossorigin async></script>

  <script is:inline>
    // ─── Global state ───
    var allSites = [];
    var allAnnotations = [];
    var currentMap = null;
    var currentSearch = '';
    var rangeMin = 1.0;
    var rangeMax = 2.0;
    var activeFilters = { city: null, century: null, style: null };
    var openPanels = []; // array of site objects currently shown

    // ─── Map init ───
    function initMap() {
      if (typeof mapkit === 'undefined') {
        setTimeout(initMap, 100);
        return;
      }

      mapkit.init({
        authorizationCallback: function (done) {
          fetch('/api/mapkit-token')
            .then(function (r) { return r.text(); })
            .then(done);
        },
      });

      currentMap = new mapkit.Map('map-container', {
        center: new mapkit.Coordinate(55.6761, 12.5683),
        region: new mapkit.CoordinateRegion(
          new mapkit.Coordinate(55.6761, 12.5683),
          new mapkit.CoordinateSpan(0.5, 0.5)
        ),
        showsCompass: mapkit.FeatureVisibility.Adaptive,
        showsScale: mapkit.FeatureVisibility.Adaptive,
        mapType: mapkit.Map.MapTypes.Hybrid,
      });

      mapkit.addEventListener('configuration-change', function handler(event) {
        if (event.status === 'Initialized') {
          mapkit.removeEventListener('configuration-change', handler);
          loadSites();
        }
      });
    }

    // ─── Load sites ───
    async function loadSites() {
      try {
        var res = await fetch('/api/sites');
        if (!res.ok) throw new Error('Failed to fetch sites');
        var data = await res.json();
        allSites = data.sites || [];

        buildFilterChips();
        applyFilters();
        handlePermalink();
      } catch (err) {
        console.error('Error loading sites:', err);
      }
    }

    // ─── Permalink handling ───
    function handlePermalink() {
      var params = new URLSearchParams(window.location.search);
      var siteId = params.get('site');
      if (!siteId) return;

      var site = allSites.find(function (s) { return s.id === siteId; });
      if (!site) return;

      // Center map on the site
      currentMap.setCenterAnimated(
        new mapkit.Coordinate(site.latitude, site.longitude)
      );
      currentMap.setRegionAnimated(
        new mapkit.CoordinateRegion(
          new mapkit.Coordinate(site.latitude, site.longitude),
          new mapkit.CoordinateSpan(0.01, 0.01)
        )
      );

      // Open detail panel
      openPanels = [site];
      renderPanels();
    }

    function updatePermalink(sites) {
      var url = new URL(window.location);
      if (sites.length === 1) {
        url.searchParams.set('site', sites[0].id);
      } else {
        url.searchParams.delete('site');
      }
      window.history.replaceState({}, '', url);
    }

    function getPermalink(site) {
      var url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set('site', site.id);
      return url.toString();
    }

    // ─── Filter chips ───
    function buildFilterChips() {
      var container = document.getElementById('filter-chips');
      container.innerHTML = '';

      // Extract unique values
      var cities = extractUnique(allSites, 'buildingAddress', extractCity);
      var styles = extractUnique(allSites, 'buildingStyle');
      var centuries = extractUnique(allSites, 'constructionYear', yearToCentury);

      if (cities.length > 1) addFilterGroup(container, 'city', 'City', cities);
      if (centuries.length > 1) addFilterGroup(container, 'century', 'Century', centuries);
      if (styles.length > 1) addFilterGroup(container, 'style', 'Style', styles);
    }

    function extractUnique(sites, field, transformFn) {
      var seen = {};
      var values = [];
      sites.forEach(function (s) {
        var raw = s[field];
        if (!raw) return;
        var val = transformFn ? transformFn(raw) : raw;
        if (val && !seen[val]) {
          seen[val] = true;
          values.push(val);
        }
      });
      return values.sort();
    }

    function extractCity(address) {
      if (!address) return null;
      // Take last part after comma as city
      var parts = address.split(',');
      var city = parts[parts.length - 1].trim();
      // Remove postal codes (digits at start)
      city = city.replace(/^\d+\s*/, '');
      return city || null;
    }

    function yearToCentury(year) {
      if (!year || year < 1000) return null;
      var c = Math.ceil(year / 100);
      return c + ordinalSuffix(c) + ' c.';
    }

    function ordinalSuffix(n) {
      if (n === 11 || n === 12 || n === 13) return 'th';
      var last = n % 10;
      if (last === 1) return 'st';
      if (last === 2) return 'nd';
      if (last === 3) return 'rd';
      return 'th';
    }

    function addFilterGroup(container, key, label, values) {
      var wrapper = document.createElement('div');
      wrapper.className = 'filter-group';

      var btn = document.createElement('button');
      btn.className = 'filter-btn';
      btn.textContent = label;
      btn.setAttribute('aria-expanded', 'false');

      var dropdown = document.createElement('div');
      dropdown.className = 'filter-dropdown hidden';

      // "All" option
      var allOpt = document.createElement('button');
      allOpt.className = 'filter-option active';
      allOpt.textContent = 'All';
      allOpt.addEventListener('click', function () {
        activeFilters[key] = null;
        updateFilterUI(dropdown, null);
        btn.textContent = label;
        btn.classList.remove('filter-active');
        applyFilters();
        dropdown.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      });
      dropdown.appendChild(allOpt);

      values.forEach(function (val) {
        var opt = document.createElement('button');
        opt.className = 'filter-option';
        opt.textContent = val;
        opt.addEventListener('click', function () {
          activeFilters[key] = val;
          updateFilterUI(dropdown, val);
          btn.textContent = val;
          btn.classList.add('filter-active');
          applyFilters();
          dropdown.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
        });
        dropdown.appendChild(opt);
      });

      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        // Close other dropdowns
        document.querySelectorAll('.filter-dropdown').forEach(function (d) {
          if (d !== dropdown) {
            d.classList.add('hidden');
            d.previousElementSibling && d.previousElementSibling.setAttribute('aria-expanded', 'false');
          }
        });
        var isHidden = dropdown.classList.contains('hidden');
        dropdown.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
      });

      wrapper.appendChild(btn);
      wrapper.appendChild(dropdown);
      container.appendChild(wrapper);
    }

    function updateFilterUI(dropdown, activeVal) {
      dropdown.querySelectorAll('.filter-option').forEach(function (opt) {
        if (activeVal === null) {
          opt.classList.toggle('active', opt.textContent === 'All');
        } else {
          opt.classList.toggle('active', opt.textContent === activeVal);
        }
      });
    }

    // Close dropdowns when clicking outside
    document.addEventListener('click', function () {
      document.querySelectorAll('.filter-dropdown').forEach(function (d) {
        d.classList.add('hidden');
      });
      document.querySelectorAll('.filter-btn').forEach(function (b) {
        b.setAttribute('aria-expanded', 'false');
      });
    });

    // ─── Apply filters ───
    function applyFilters() {
      if (allAnnotations.length > 0) {
        currentMap.removeAnnotations(allAnnotations);
      }

      var filtered = allSites.filter(function (site) {
        if (site.dValue < rangeMin || site.dValue > rangeMax) return false;

        // Search
        if (currentSearch) {
          var q = currentSearch.toLowerCase();
          var searchable = [
            site.buildingName, site.buildingAddress, site.architect,
            site.buildingStyle, site.buildingType, site.dValue.toFixed(3),
          ].filter(Boolean).join(' ').toLowerCase();
          if (!searchable.includes(q)) return false;
        }

        // City filter
        if (activeFilters.city) {
          var city = extractCity(site.buildingAddress);
          if (city !== activeFilters.city) return false;
        }

        // Century filter
        if (activeFilters.century) {
          var century = yearToCentury(site.constructionYear);
          if (century !== activeFilters.century) return false;
        }

        // Style filter
        if (activeFilters.style) {
          if (site.buildingStyle !== activeFilters.style) return false;
        }

        return true;
      });

      // Update count
      var countEl = document.getElementById('search-count');
      var isFiltered = currentSearch || rangeMin > 1.0 || rangeMax < 2.0
        || activeFilters.city || activeFilters.century || activeFilters.style;
      if (isFiltered) {
        countEl.textContent = filtered.length + ' of ' + allSites.length;
      } else {
        countEl.textContent = allSites.length > 0 ? allSites.length + ' sites' : '';
      }

      // Create annotations
      allAnnotations = filtered.map(function (site) {
        var coord = new mapkit.Coordinate(site.latitude, site.longitude);
        var color = dValueToColor(site.dValue);
        var title = site.buildingName || 'D = ' + site.dValue.toFixed(3);
        var subtitle = site.buildingName ? 'D = ' + site.dValue.toFixed(3) : '';

        var annotation = new mapkit.MarkerAnnotation(coord, {
          color: color,
          title: title,
          subtitle: subtitle,
          glyphText: site.dValue.toFixed(1),
        });

        annotation._fractuneSite = site;

        annotation.addEventListener('select', function (e) {
          var shiftKey = window._lastClickShift || false;
          handleMarkerClick(site, shiftKey);
        });

        return annotation;
      });

      currentMap.addAnnotations(allAnnotations);

      if (allAnnotations.length > 1) {
        currentMap.showItems(allAnnotations, {
          animate: true,
          padding: new mapkit.Padding(80, 60, 60, 60),
        });
      } else if (allAnnotations.length === 1) {
        currentMap.setCenterAnimated(allAnnotations[0].coordinate);
      }
    }

    // Track shift key globally for marker clicks
    window._lastClickShift = false;
    document.addEventListener('mousedown', function (e) {
      window._lastClickShift = e.shiftKey;
    });
    document.addEventListener('touchstart', function () {
      window._lastClickShift = false;
    });

    function dValueToColor(d) {
      var t = Math.max(0, Math.min(1, (d - 1.0) / 1.0));
      var sweet = 0.4;
      var dist = Math.abs(t - sweet) / Math.max(sweet, 1 - sweet);
      dist = Math.min(1, dist);
      var r = Math.round(50 + dist * 180);
      var g = Math.round(160 - dist * 120);
      var b = Math.round(50 - dist * 20);
      return 'rgb(' + r + ', ' + g + ', ' + b + ')';
    }

    // ─── Multi-panel detail view ───
    function handleMarkerClick(site, shiftKey) {
      if (shiftKey) {
        // Shift-click: add panel if not already open
        var alreadyOpen = openPanels.some(function (s) { return s.id === site.id; });
        if (!alreadyOpen) {
          openPanels.push(site);
        }
      } else {
        // Normal click: replace all with single panel
        openPanels = [site];
      }
      updatePermalink(openPanels);
      renderPanels();
    }

    function closePanel(siteId) {
      openPanels = openPanels.filter(function (s) { return s.id !== siteId; });
      updatePermalink(openPanels);
      renderPanels();
    }

    function renderPanels() {
      var container = document.getElementById('detail-panels');
      container.innerHTML = '';

      openPanels.forEach(function (site, index) {
        var panel = document.createElement('div');
        panel.className = 'site-detail';
        panel.style.animationDelay = (index * 0.05) + 's';

        var dColor = dValueToColor(site.dValue);

        var details = [];
        if (site.buildingAddress) details.push(site.buildingAddress);
        if (site.architect) details.push(site.architect);
        if (site.constructionYear) details.push(String(site.constructionYear));

        var styleInfo = [];
        if (site.buildingStyle) styleInfo.push(site.buildingStyle);
        if (site.buildingType) styleInfo.push(site.buildingType);

        var dateStr = site.analyzedAt
          ? 'Analysed ' + new Date(site.analyzedAt).toLocaleDateString('en-GB')
          : '';

        var permalink = getPermalink(site);

        panel.innerHTML =
          '<button class="close-btn" aria-label="Close">&times;</button>' +
          '<h3>' + escapeHtml(site.buildingName || 'Unnamed site') + '</h3>' +
          '<p class="detail-d-value">D = <strong style="color:' + dColor + '">' + site.dValue.toFixed(4) + '</strong></p>' +
          (details.length ? '<p class="detail-meta">' + escapeHtml(details.join(' · ')) + '</p>' : '') +
          (styleInfo.length ? '<p class="detail-style">' + escapeHtml(styleInfo.join(' · ')) + '</p>' : '') +
          (dateStr ? '<p class="detail-date">' + dateStr + '</p>' : '') +
          '<a class="detail-permalink" href="' + permalink + '" title="Copy permalink" onclick="copyPermalink(event, this)">Permalink</a>';

        panel.querySelector('.close-btn').addEventListener('click', function () {
          closePanel(site.id);
        });

        container.appendChild(panel);
      });

      // Show comparison hint if exactly one panel
      if (openPanels.length === 1) {
        var hint = document.createElement('p');
        hint.className = 'compare-hint';
        hint.textContent = 'Shift-click another marker to compare';
        container.appendChild(hint);
      }
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function copyPermalink(e, el) {
      e.preventDefault();
      var url = el.href;
      navigator.clipboard.writeText(url).then(function () {
        var original = el.textContent;
        el.textContent = 'Copied!';
        setTimeout(function () { el.textContent = original; }, 1500);
      });
    }

    // ─── Event listeners ───
    document.addEventListener('DOMContentLoaded', function () {
      // Search input
      var searchInput = document.getElementById('search-input');
      var searchTimeout;
      searchInput.addEventListener('input', function () {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(function () {
          currentSearch = searchInput.value.trim();
          applyFilters();
        }, 200);
      });

      searchInput.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          searchInput.value = '';
          currentSearch = '';
          applyFilters();
          searchInput.blur();
        }
      });

      initRangeSlider();
    });

    // ─── Range slider ───
    function initRangeSlider() {
      var track = document.getElementById('range-track');
      var handleLeft = document.getElementById('handle-left');
      var handleRight = document.getElementById('handle-right');
      var selected = document.getElementById('range-selected');
      var valuesEl = document.getElementById('range-values');

      var D_MIN = 1.0;
      var D_MAX = 2.0;

      function dToPercent(d) { return ((d - D_MIN) / (D_MAX - D_MIN)) * 100; }
      function percentToD(p) { return D_MIN + (p / 100) * (D_MAX - D_MIN); }

      function updateVisuals() {
        var leftPct = dToPercent(rangeMin);
        var rightPct = dToPercent(rangeMax);
        handleLeft.style.left = leftPct + '%';
        handleRight.style.left = rightPct + '%';
        selected.style.left = leftPct + '%';
        selected.style.width = (rightPct - leftPct) + '%';
        valuesEl.textContent = 'D ' + rangeMin.toFixed(1) + ' – ' + rangeMax.toFixed(1);
        handleLeft.setAttribute('aria-valuenow', rangeMin.toFixed(2));
        handleRight.setAttribute('aria-valuenow', rangeMax.toFixed(2));
      }

      updateVisuals();

      function startDrag(handle, isLeft) {
        var onMove = function (e) {
          e.preventDefault();
          var rect = track.getBoundingClientRect();
          var clientX = e.touches ? e.touches[0].clientX : e.clientX;
          var pct = Math.max(0, Math.min(100, ((clientX - rect.left) / rect.width) * 100));
          var d = percentToD(pct);
          d = Math.round(d * 20) / 20;
          d = Math.max(D_MIN, Math.min(D_MAX, d));

          if (isLeft) {
            rangeMin = Math.min(d, rangeMax - 0.05);
          } else {
            rangeMax = Math.max(d, rangeMin + 0.05);
          }

          updateVisuals();
          applyFilters();
        };

        var onEnd = function () {
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onEnd);
          document.removeEventListener('touchmove', onMove);
          document.removeEventListener('touchend', onEnd);
          handle.classList.remove('dragging');
        };

        handle.classList.add('dragging');
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onEnd);
        document.addEventListener('touchmove', onMove, { passive: false });
        document.addEventListener('touchend', onEnd);
      }

      handleLeft.addEventListener('mousedown', function (e) { e.preventDefault(); startDrag(handleLeft, true); });
      handleLeft.addEventListener('touchstart', function (e) { e.preventDefault(); startDrag(handleLeft, true); }, { passive: false });
      handleRight.addEventListener('mousedown', function (e) { e.preventDefault(); startDrag(handleRight, false); });
      handleRight.addEventListener('touchstart', function (e) { e.preventDefault(); startDrag(handleRight, false); }, { passive: false });

      track.addEventListener('click', function (e) {
        if (e.target === handleLeft || e.target === handleRight) return;
        var rect = track.getBoundingClientRect();
        var pct = ((e.clientX - rect.left) / rect.width) * 100;
        var d = Math.round(percentToD(pct) * 20) / 20;
        var distLeft = Math.abs(d - rangeMin);
        var distRight = Math.abs(d - rangeMax);
        if (distLeft < distRight) {
          rangeMin = Math.min(d, rangeMax - 0.05);
        } else {
          rangeMax = Math.max(d, rangeMin + 0.05);
        }
        updateVisuals();
        applyFilters();
      });

      track.addEventListener('dblclick', function () {
        rangeMin = D_MIN;
        rangeMax = D_MAX;
        updateVisuals();
        applyFilters();
      });
    }

    initMap();
  </script>
</BaseLayout>

<style>
  .map-page {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  /* ─── Header ─── */
  .map-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1.5rem;
    background: #ffffff;
    border-bottom: 1px solid var(--color-border);
  }

  .map-logo {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .map-logo-icon {
    height: 1.0em;
    width: auto;
    vertical-align: middle;
    transform: translateY(-1px);
  }

  .map-title {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  /* ─── Filter chips ─── */
  .filter-chips {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-left: 0.5rem;
    overflow-x: auto;
    flex: 1;
    min-width: 0;
  }

  .filter-group {
    position: relative;
    flex-shrink: 0;
  }

  .filter-btn {
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    border-radius: 980px;
    font-size: 0.6875rem;
    font-family: var(--font-sans);
    background: #fff;
    color: var(--color-text-secondary);
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--transition);
  }

  .filter-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .filter-btn.filter-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .filter-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    z-index: 20;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    min-width: 140px;
    max-height: 240px;
    overflow-y: auto;
    padding: 0.25rem 0;
  }

  .filter-dropdown.hidden {
    display: none;
  }

  .filter-option {
    display: block;
    width: 100%;
    padding: 0.375rem 0.75rem;
    border: none;
    background: none;
    font-size: 0.75rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    text-align: left;
    cursor: pointer;
    transition: background var(--transition);
  }

  .filter-option:hover {
    background: var(--color-bg-secondary);
  }

  .filter-option.active {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ─── Search ─── */
  .search-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .search-input {
    padding: 0.3125rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 980px;
    font-size: 0.6875rem;
    font-family: var(--font-sans);
    background: #fff;
    color: var(--color-text);
    outline: none;
    width: 160px;
    transition: border-color var(--transition), box-shadow var(--transition), width var(--transition);
  }

  .search-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(18, 40, 62, 0.1);
    width: 240px;
  }

  .search-input::placeholder {
    color: var(--color-text-secondary);
    opacity: 0.5;
  }

  .search-count {
    font-size: 0.625rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  /* ─── Map ─── */
  #map-container {
    width: 100%;
    height: 100%;
  }

  /* ─── Range slider legend ─── */
  .map-legend {
    position: absolute;
    bottom: 2rem;
    left: 1.5rem;
    z-index: 10;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
